# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
web-build/
expo-env.d.ts

# dist/ is intentionally NOT ignored so the pre-built frontend is committed to git
# This allows Render to deploy without needing the memory-intensive Expo build step

# Native
ios/
android/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# Cursor/local artifacts
.local/

# typescript
*.tsbuildinfo
.vercel

# Server build output (built by Render on deployment)
server_dist/

.env
